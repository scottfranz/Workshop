# Supabase — get these from supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# TMDb — get from themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key-here

# Goodreads — your user ID (the number in your profile URL)
GOODREADS_USER_ID=38583676

# Password protection
# DASHBOARD_PASSWORD is what you type to log in — pick something strong
# SESSION_SECRET is any random string — just mash the keyboard for ~20 chars
DASHBOARD_PASSWORD=pick-a-strong-password-here
SESSION_SECRET=some-long-random-string-abc123xyz789qrs

# Regalia calendar notifications
# Get a free Resend API key at resend.com
RESEND_API_KEY=re_your_resend_key_here
# The email address to send notifications TO (your email)
NOTIFICATION_EMAIL=you@youremail.com
# The from address — must be a domain you've verified in Resend
# If you don't have a domain, Resend lets you use onboarding@resend.dev for testing
EMAIL_FROM=The Workshop <you@yourdomain.com>
# A secret to manually trigger the cron at /api/cron/regalia?secret=...
CRON_SECRET=pick-another-random-string
